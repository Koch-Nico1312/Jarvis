{
  "manifest_version": 3,
  "name": "Jarvis Companion",
  "version": "0.1.0",
  "description": "Connects the browser to Jarvis workspaces, files, terminal actions, and remote agents.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_title": "Jarvis Companion",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
